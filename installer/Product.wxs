<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="Lauchwatch_x86"
    Language="1031"
    Version="1.0.0.0"
    Manufacturer="KM310"
    UpgradeCode="A1234567-BBBB-4444-9999-ABCDEF123456">

    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" />

    <!-- Standard Installationspfad -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <MediaTemplate />

    <Feature Id="MainFeature" Title="Lauchwatch_x86" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ShortcutComponent" />
      <ComponentRef Id="WebView2Runtime" />
    </Feature>

    <!-- UI mit Pfadauswahl + Shortcut-Checkbox -->
    <UIRef Id="WixUI_InstallDir" />

    <Property Id="ADD_SHORTCUT" Value="1" />
    <UI>
      <Publish Dialog="CustomizeDlg" Control="Next" Event="DoAction" Value="SetShortcut">
        1
      </Publish>
    </UI>

    <CustomAction Id="SetShortcut" Property="ADD_SHORTCUT" Value="[ADDLOCAL]" />

    <!-- Dateien -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="Lauchwatch">
          <Component Id="AppFiles" Guid="*">
            <File Id="LauchwatchEXE" Source="Lauchwatch_x86.exe" KeyPath="yes" />
            <File Id="IconDLL" Source="icon.dll" />
          </Component>

          <!-- Optionaler Shortcut -->
          <Component Id="ShortcutComponent" Guid="*">
            <Condition>ADD_SHORTCUT</Condition>
            <Shortcut
              Id="StartMenuShortcut"
              Name="Lauchwatch_x86"
              Directory="ProgramMenuFolder"
              WorkingDirectory="INSTALLFOLDER"
              Icon="AppIcon"
              IconIndex="0"
              Target="[INSTALLFOLDER]Lauchwatch_x86.exe" />
            <RemoveFolder Id="RemoveShortcutFolder" Directory="ProgramMenuFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\KM310\Lauchwatch" Name="installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>

        </Directory>
      </Directory>

      <!-- Startmenü -->
      <Directory Id="ProgramMenuFolder" Name="Programs" />
    </Directory>

    <!-- Icon -->
    <Icon Id="AppIcon" SourceFile="icon.dll" />

    <!-- WebView2 Runtime -->
    <Component Id="WebView2Runtime" Guid="*">
      <File Id="WV2Installer" Source="MicrosoftEdgeWebView2RuntimeInstallerX86.exe" KeyPath="yes" />
      <CustomAction Id="InstallWV2"
                    FileKey="WV2Installer"
                    ExeCommand="/install"
                    Execute="deferred"
                    Return="ignore"
                    Impersonate="no" />
      <InstallExecuteSequence>
        <Custom Action="InstallWV2" After="InstallFiles">NOT Installed</Custom>
      </InstallExecuteSequence>
    </Component>

  </Product>
</Wix>
